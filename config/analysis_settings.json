{
  "interesting_strings_preview_limit": 8,
  "analyst_highlight_limits": {
    "default_per_type": 5,
    "top_findings": 6,
    "contextual_findings": 6
  },
  "entropy": {
    "high_entropy_threshold": 7.2,
    "min_high_entropy_sections_for_likely_packed": 1
  },
  "artifact_filters": {
    "trusted_pki_domains_or_patterns": [
      "crl",
      "ocsp",
      "cacerts",
      "certificates",
      "digicert",
      "globalsign",
      "letsencrypt",
      "lencr.org",
      "sectigo",
      "comodoca",
      "entrust",
      "microsoft.com/pki",
      "microsoft.com/fwlink"
    ],
    "trusted_pki_keywords": [
      "certificate",
      "code signing",
      "timestamp",
      "timestamping",
      "cert chain",
      "x509"
    ],
    "build_artifact_patterns": [
      "\\\\obj\\\\",
      "\\\\bin\\\\",
      "\\\\build\\\\",
      "\\\\dist\\\\",
      "\\\\release\\\\",
      "\\\\debug\\\\",
      ".pdb",
      "visual studio",
      "msvc",
      "source map",
      "sourcemap"
    ],
    "installer_artifact_patterns": [
      "nullsoft",
      "nsis",
      "$pluginsdir",
      "inno setup",
      "wix",
      "msiexec",
      "installshield",
      "squirrel",
      "update.exe",
      "uninstall",
      "setup wizard",
      "bootstrapper",
      "electron",
      "tauri",
      "app.asar",
      "nsisdl"
    ],
    "contextual_ip_values": [
      "0.0.0.0",
      "1.0.0.0",
      "1.0.0.1",
      "5.0.0.0",
      "6.0.0.0",
      "10.0.0.0"
    ],
    "semantic_ip_rules": {
      "local_only_ip_values": [
        "127.0.0.1",
        "169.254.169.254"
      ],
      "version_context_terms": [
        "assemblyversion",
        "assembly file version",
        "assemblyversionattribute",
        "productversion",
        "fileversion",
        "runtimeversion",
        "targetframework"
      ],
      "ping_context_terms": [
        "ping ",
        "ping.exe",
        "sleep ",
        "timeout ",
        "cmd /c ping",
        "test-connection"
      ]
    },
    "command_high_confidence_terms": [
      "-enc",
      "frombase64string",
      "downloadstring",
      "downloadfile",
      "invoke-expression",
      "iwr ",
      "invoke-webrequest",
      "bitsadmin /transfer",
      "certutil -urlcache",
      "regsvr32 /s",
      "mshta http"
    ],
    "command_contextual_terms": [
      "msiexec",
      "uninstall",
      "setup",
      "install",
      "update.exe",
      "squirrel",
      "electron",
      "tauri"
    ],
    "mutex_contextual_terms": [
      "setup",
      "update",
      "nsis",
      "installer",
      "electron",
      "tauri"
    ]
  },
  "capabilities": {
    "source_weights": {
      "API": 3,
      "string": 2,
      "YARA": 4
    },
    "weak_indicators": [
      "http://",
      "https://",
      "startup",
      "debugger"
    ],
    "contextual_indicators": [
      "run\\",
      "sandbox",
      "vmware",
      "virtualbox",
      "user-agent"
    ],
    "thresholds": {
      "minimum_score_for_medium": 4,
      "minimum_score_for_high": 7,
      "minimum_sources_for_high": 2
    },
    "per_capability_overrides": {
      "anti_analysis": {
        "minimum_score_for_medium": 5,
        "minimum_score_for_high": 7
      },
      "downloader_behavior": {
        "minimum_score_for_medium": 5,
        "minimum_score_for_high": 7
      },
      "networking": {
        "minimum_score_for_medium": 5,
        "minimum_score_for_high": 7
      },
      "persistence": {
        "minimum_score_for_medium": 5,
        "minimum_score_for_high": 7
      }
    }
  },
  "context_detection": {
    "dotnet_import_indicators": [
      "mscoree.dll"
    ],
    "dotnet_symbol_indicators": [
      "_CorExeMain",
      "_CorDllMain"
    ],
    "dotnet_string_patterns": [
      "system.runtime",
      "mscorlib",
      "assemblyversion",
      "targetframework",
      "v4.0.30319",
      "clr"
    ],
    "go_string_patterns": [
      "go build id",
      "golang",
      "runtime.g",
      "runtime.goexit",
      "runtime.main",
      "gopclntab"
    ],
    "go_section_patterns": [
      ".gopclntab",
      ".go.buildinfo"
    ],
    "installer_patterns": [
      "nullsoft",
      "nsis",
      "$pluginsdir",
      "inno setup",
      "wix",
      "msiexec",
      "installshield",
      "squirrel",
      "update.exe",
      "uninstall",
      "setup wizard",
      "bootstrapper",
      "electron",
      "tauri",
      "app.asar",
      "installer"
    ],
    "runtime_noise_patterns": [
      "system.runtime",
      "mscorlib",
      "presentationframework",
      "windows.forms",
      "runtime.goexit",
      "runtime.main",
      "gopclntab",
      "electron",
      "app.asar",
      "tauri"
    ],
    "minimum_installer_signals": 2,
    "minimum_runtime_noise_signals": 2,
    "sparse_import_thresholds": {
      "max_dll_count": 3,
      "max_api_count": 25
    }
  },
  "behavior_domains": {
    "anti_analysis": {
      "categories": [],
      "terms": [
        "sandbox",
        "vmware",
        "virtualbox",
        "wireshark",
        "processhacker",
        "debugger"
      ]
    },
    "credentials_or_auth": {
      "categories": [],
      "terms": [
        "password",
        "credential",
        "token",
        "cookie",
        "logon",
        "lsass"
      ]
    },
    "crypto_or_encoding": {
      "categories": [],
      "terms": [
        "base64",
        "aes",
        "rsa",
        "sha256",
        "encrypt",
        "decrypt"
      ]
    },
    "execution": {
      "categories": [
        "commands_or_lolbins",
        "powershell"
      ],
      "terms": [
        "powershell",
        "cmd.exe",
        "rundll32",
        "regsvr32",
        "mshta",
        "schtasks",
        "createprocess"
      ]
    },
    "filesystem": {
      "categories": [
        "file_paths",
        "appdata_or_temp"
      ],
      "terms": [
        "\\temp\\",
        "\\appdata\\",
        "programdata",
        "startup",
        ".exe"
      ]
    },
    "installer_or_packager": {
      "categories": [],
      "terms": [
        "nullsoft",
        "nsis",
        "installer",
        "uninstall",
        "msiexec",
        "squirrel",
        "electron",
        "tauri",
        "app.asar"
      ]
    },
    "network": {
      "categories": [
        "urls",
        "domains",
        "ips"
      ],
      "terms": [
        "http://",
        "https://",
        "socket",
        "user-agent",
        "download",
        "connect"
      ]
    },
    "registry": {
      "categories": [
        "registry_paths"
      ],
      "terms": [
        "hkey_current_user",
        "currentversion\\run",
        "runonce",
        "software\\microsoft\\windows"
      ]
    },
    "runtime_or_language": {
      "categories": [],
      "terms": [
        "system.runtime",
        "mscorlib",
        "assemblyversion",
        "targetframework",
        "go build id",
        "runtime.goexit",
        "gopclntab",
        "electron",
        "tauri"
      ]
    }
  },
  "behavior_chains": {
    "download_write_execute_chain": {
      "minimum_download_signals": 2,
      "minimum_execution_signals": 1,
      "minimum_filesystem_signals": 1
    }
  },
  "intent_inference": {
    "high_confidence_min_rationale_count": 3
  },
  "interpretation": {
    "installer_or_packager_patterns": [
      "nullsoft",
      "nsis",
      "$pluginsdir",
      "inno setup",
      "squirrel",
      "electron",
      "tauri",
      "app.asar",
      "update.exe",
      "msiexec",
      "installshield",
      "bootstrapper"
    ],
    "certificate_or_signing_patterns": [
      "certificate",
      "code signing",
      "timestamp",
      "ocsp",
      "crl"
    ],
    "minimum_installer_signals": 2
  },
  "yara_reporting": {
    "warning_excerpt_limit": 5
  },
  "scoring": {
    "weights": {
      "high_confidence_capability": 20,
      "medium_confidence_capability": 12,
      "low_confidence_capability": 6,
      "behavior_chain": 8,
      "yara_hit": 18,
      "high_entropy_section": 10,
      "likely_packed": 15,
      "suspicious_url": 6,
      "suspicious_registry_path": 5,
      "suspicious_command": 5,
      "contextual_command": 2,
      "suspicious_powershell": 7,
      "degraded_mode_penalty": -10
    },
    "context_adjustments": {
      "go_high_entropy_penalty": -10,
      "dotnet_sparse_obfuscated_bonus": 10,
      "installer_like_penalty": -12,
      "runtime_noise_penalty": -5
    },
    "severity_thresholds": {
      "high": 55,
      "medium": 25
    }
  }
}
